<header class="chat-page__header">
  <div class="chat-page__header-main">
    <span class="chat-page__status-dot" aria-hidden="true"></span>
    <h1 class="chat-page__title">{{peerName}}</h1>
  </div>
  <div class="chat-page__toolbar" role="toolbar" aria-label="Действия в чате">
    {{{IconButton type="button" icon="fa-solid fa-thumbtack" ariaLabel="Закрепить" className="chat-page__toolbar-btn"}}}
    {{{IconButton type="button" icon="fa-solid fa-magnifying-glass" ariaLabel="Поиск" className="chat-page__toolbar-btn"}}}
    {{{IconButton type="button" icon="fa-solid fa-trash" ariaLabel="Удалить чат" className="chat-page__toolbar-btn"}}}
  </div>
</header>
