<header class="chat-page__header">
  <div class="chat-page__header-main">
    {{#if showStatusDot}}
      <span class="chat-page__status-dot" aria-hidden="true"></span>
    {{/if}}
    <h1 class="chat-page__title">{{peerName}}</h1>
  </div>
  <div class="chat-page__toolbar" role="toolbar" aria-label="Действия в чате">
    {{#if showGroupMemberActions}}
      <button
        type="button"
        class="icon-button chat-page__toolbar-btn"
        data-chat-action="group-members"
        aria-label="Участники группы"
      >
        <i class="fa-solid fa-users" aria-hidden="true"></i>
      </button>
    {{/if}}
    <button
      type="button"
      class="icon-button chat-page__toolbar-btn chat-page__toolbar-btn--delete"
      data-chat-action="delete-chat"
      aria-label="Удалить чат"
    >
      <i class="fa-solid fa-trash" aria-hidden="true"></i>
    </button>
  </div>
</header>
