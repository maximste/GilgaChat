<aside class="messenger-sidebar">
  <div class="messenger-sidebar__top">
    <nav class="messenger-sidebar__top-links">
      {{#each topLinks}}
        {{{Link text=text href=href className=className}}}
      {{/each}}
    </nav>
    {{{Button type="button" text=appTitle className="messenger-sidebar__app-title" ariaHaspopup="listbox" ariaExpanded="false" rightSection=appTitleRightSection}}}
    {{{Search placeholder="Search" ariaLabel="Search"}}}
  </div>

  <nav class="messenger-sidebar__nav">
    <section class="messenger-sidebar__section">
      <button type="button" class="messenger-sidebar__section-head" aria-expanded="true" data-section="dm">
        DIRECT MESSAGES
      </button>
      <ul class="messenger-sidebar__list" role="list">
        {{#each directMessages}}
          <li>
            <button type="button" class="messenger-sidebar__item" data-chat="dm-{{@index}}">
              <span class="messenger-sidebar__item-avatar messenger-sidebar__item-avatar--user" aria-hidden="true"></span>
              <span class="messenger-sidebar__item-info">
                <span class="messenger-sidebar__item-name">
                  <span class="messenger-sidebar__status-dot messenger-sidebar__status-dot--{{statusType}}" aria-hidden="true"></span>
                  {{lastName}} {{firstName}}
                </span>
                <span class="messenger-sidebar__item-meta">{{preview}}</span>
              </span>
            </button>
          </li>
        {{/each}}
      </ul>
    </section>
    <section class="messenger-sidebar__section">
      <button type="button" class="messenger-sidebar__section-head" aria-expanded="true" data-section="groups">
        GROUPS
      </button>
      <ul class="messenger-sidebar__list" role="list">
        {{#each groups}}
          <li>
            <button type="button" class="messenger-sidebar__item" data-chat="group-{{@index}}">
              <span class="messenger-sidebar__item-avatar" aria-hidden="true">
                <i class="fa-solid {{iconClass}}" aria-hidden="true"></i>
              </span>
              <span class="messenger-sidebar__item-info">
                <span class="messenger-sidebar__item-name">{{name}}</span>
                <span class="messenger-sidebar__item-meta">{{preview}}</span>
              </span>
            </button>
          </li>
        {{/each}}
      </ul>
    </section>
  </nav>

  <div class="messenger-sidebar__user">
    <div class="messenger-sidebar__user-avatar" aria-hidden="true"></div>
    <div class="messenger-sidebar__user-info">
      <span class="messenger-sidebar__user-name">{{currentUser.firstName}} {{currentUser.lastName}}</span>
      <span class="messenger-sidebar__user-status">
        <span class="messenger-sidebar__status-dot messenger-sidebar__status-dot--green" aria-hidden="true"></span>
        {{currentUser.status}}
      </span>
    </div>
    <a href="#profile" class="messenger-sidebar__user-settings" aria-label="Settings">
      <i class="fa-solid fa-gear" aria-hidden="true"></i>
    </a>
  </div>
</aside>
