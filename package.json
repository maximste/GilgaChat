{
  "name": "gilgachat",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "prebuild": "tsc --noEmit",
    "build": "npm run prebuild && vite build",
    "preview": "vite preview",
    "start": "npm run build && npm run preview",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint:css": "stylelint **/*.css",
    "lint": "npm run lint:eslint && npm run lint:stylelint",
    "lint:fix": "npm run ****format:fix && npm run lint:eslint:write && npm run lint:stylelint:write",
    "lint:eslint": "eslint . --cache",
    "lint:eslint:write": "eslint . --fix",
    "lint:stylelint": "stylelint **/*.scss --cache",
    "lint:stylelint:write": "stylelint **/*.scss --fix",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^25.3.2",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "sass": "^1.97.3",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1"
  },
  "lint-staged": {
    "*.{ts,mts,cts,js,mjs,cjs}": "eslint --fix",
    "*.{scss,css}": "stylelint --fix",
    "*.{ts,js,json,md,scss,css}": "prettier --write"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "dotenv": "^17.3.1",
    "handlebars": "^4.7.8"
  }
}
